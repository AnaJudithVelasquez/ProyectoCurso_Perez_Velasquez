<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Ventas | Fruver JJ</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-yellow-50">

<div class="container mt-5">

    <!-- ALERTAS -->

<% if (mensaje === 'ok') { %>

    <div class="alert alert-success alert-dismissible fade show" role="alert">

        ✅ Venta registrada correctamente

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>

<% } %>

<% if (mensaje === 'stock') { %>

    <div class="alert alert-danger alert-dismissible fade show" role="alert">

        ❌ Stock insuficiente para realizar la venta

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>

<% } %>

<% if (mensaje === 'inactivo') { %>

    <div class="alert alert-warning alert-dismissible fade show" role="alert">

        🚫 No puedes vender un producto inactivo

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>

<% } %>

    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap">

        <a href="/" class="btn btn-outline-success btn-lg shadow-sm">
            ⬅ Volver al inicio
        </a>

        <div class="text-center flex-grow-1">
            <h1 class="fw-bold text-warning" style="font-size: 3rem;">
                💰 Gestión de Ventas
            </h1>

            <p class="text-gray-600">
                Registra ventas de frutas, verduras y hortalizas 🥑🍎🥦
            </p>
        </div>

    </div>

    <!-- FORMULARIO -->
    <div class="card shadow-lg p-4 mb-5 border-0 rounded-4">

        <h4 class="fw-bold text-warning mb-4">
            🛒 Agregar al carrito
        </h4>

        <form action="/agregar-a-venta" method="POST">

            <div class="row">

                <!-- PRODUCTO -->
                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Producto
                    </label>

                    <select name="producto_id" class="form-select" required>

                        <option value="">
                            Selecciona un producto
                        </option>

                        <% productos.forEach(producto => { %>

                            <option value="<%= producto.id %>">

                               <%= producto.nombre %>
                               | 💰 $<%= producto.precio %>
                               | 📦 Stock: <%= producto.stock %>

                               <% if (!producto.estado) { %>
                               | 🚫 INACTIVO
                               <% } %>

                            </option>

                        <% }) %>

                    </select>

                </div>

                <!-- CANTIDAD -->
                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Cantidad
                    </label>

                    <input
                        type="number"
                        name="cantidad"
                        class="form-control"
                        placeholder="Cantidad vendida"
                        required
                    >

                </div>

            </div>

            <!-- BOTÓN -->
            <button class="btn btn-warning w-100 fw-bold mt-3">

                🛒 Agregar al carrito

            </button>

        </form>

    </div>

    <!-- TABLA -->
    <div class="card shadow-lg p-5 border-0 rounded-4 mb-5">

        <h4 class="fw-bold text-warning mb-4">
            📋 Historial de ventas
        </h4>

        <table class="table table-hover align-middle text-center mt-4">

            <thead class="table-warning">

                <tr>
                    <th>🧾 Venta #</th>
                    <th>🛒 Producto</th>
                    <th>📦 Cantidad</th>
                    <th>💰 Total</th>
                    <th>📅 Fecha</th>
                    <th>📌 Estado</th>
                    <th>⚙️ Acciones</th>
                </tr>

            </thead>

            <tbody>

                <% ventas.forEach(venta => { %>

                    <tr class="<%= !venta.estado ? 'table-danger text-decoration-line-through' : '' %>">
                        <td class="fw-bold text-primary">
    #<%= venta.numero_venta %>
</td>
                        <td class="fw-semibold">
                            <%= venta.nombre %>
                        </td>

                        <td>
                            <span class="badge bg-warning text-dark">
                                <%= venta.cantidad %>
                            </span>
                        </td>

                        <td class="fw-bold text-success">
                            $ <%= venta.total %>
                        </td>

                        <td>
                            <%= new Date(venta.fecha).toLocaleString() %>
                        </td>

                        <td>

                            <% if (venta.estado) { %>

                                <span class="badge bg-success">
                                    Activa
                                </span>

                            <% } else { %>

                                <span class="badge bg-danger">
                                    Cancelada
                                </span>

                            <% } %>

                        </td>

                        <td>

                            <% if (venta.estado) { %>

                                <a href="/editar-venta/<%= venta.id %>"
                                   class="btn btn-warning btn-sm">

                                   ✏️ Editar

                                </a>

                                <a href="/cancelar-venta/<%= venta.id %>"
                                   class="btn btn-danger btn-sm">

                                   ❌ Cancelar

                                </a>

                            <% } else { %>

                                <span class="text-muted">
                                    Cancelada
                                </span>

                            <% } %>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

    <!-- CARRITO -->
    <div class="card shadow-lg p-4 border-0 rounded-4 mt-5 mb-5">

        <h3 class="fw-bold text-success mb-4">

            🛒 Venta en proceso

        </h3>

        <% if (carrito.length > 0) { %>

            <table class="table table-hover text-center align-middle">

                <thead class="table-success">

                    <tr>

                      <th>🍎 Producto</th>
        <th>💰 Precio</th>
        <th>📦 Cantidad</th>
        <th>💵 Subtotal</th>
        <th>⚙️ Acción</th>

                    </tr>

                </thead>

                <tbody>

                    <% let totalVenta = 0; %>

                    <% carrito.forEach((item, index) => { %>

                        <% totalVenta += item.subtotal; %>

                        <tr>

                            <td>
                                <%= item.nombre %>
                            </td>

                            <td>
                                $ <%= item.precio %>
                            </td>

                            <td>
                                <%= item.cantidad %>
                            </td>

                            <td class="fw-bold text-success">

                                $ <%= item.subtotal %>

                            </td>

                            <td>

    <a href="/quitar-del-carrito/<%= index %>"
       class="btn btn-danger btn-sm">

       ❌ Quitar

    </a>

</td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

            <div class="text-end mt-3">

                <h4 class="fw-bold text-success">

                    💰 Total:
                    $ <%= totalVenta %>

                </h4>

            </div>

            <!-- BOTÓN -->
            <form action="/finalizar-venta" method="POST">

                <button class="btn btn-success btn-lg w-100 mt-3">

                    ✅ Finalizar venta

                </button>

            </form>

        <% } else { %>

            <div class="alert alert-warning text-center">

                No hay productos agregados a la venta.

            </div>

        <% } %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>