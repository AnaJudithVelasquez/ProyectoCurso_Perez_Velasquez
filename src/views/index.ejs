<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Fruver Aguacates JJ 🥑</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
     
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600;800&display=swap" rel="stylesheet">

</head>

<body class="bg-gradient-to-r from-green-100 to-green-50 min-h-screen flex items-center">

<div class="container text-center">

    <h1 class="display-3 fw-bold text-success titulo-principal">
        🥑 Fruver Aguacates JJ
    </h1>

    <p class="mb-5 text-gray-600 text-lg">
        Sistema de gestión de frutas, verduras y hortalizas
    </p>

    <div class="row justify-content-center g-4">

        <!-- INVENTARIO -->
        <div class="col-md-5">
            <div class="card shadow-lg p-5 rounded-4 card-hover">
                <h2 class="mb-3 fw-bold">📦 Inventario</h2>
                <p class="mb-4">Administra todos tus productos fácilmente</p>
                <a href="/productos" class="btn btn-success btn-lg w-100">Ir a productos</a>
            </div>
        </div>

        <!-- VENTAS -->
        <div class="col-md-5">
            <div class="card shadow-lg p-5 rounded-4 card-hover">
                <h2 class="mb-3 fw-bold">💰 Ventas</h2>
                <p class="mb-4">Registra y controla tus ventas</p>
                <a href="/ventas" class="btn btn-warning btn-lg w-100">Ir a ventas</a>
            </div>
        </div>

    </div>

</div>

</body>
</html>