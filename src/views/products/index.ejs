<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Productos | Fruver JJ</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/styles.css">

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-green-50">

<div class="container mt-5">

    <!-- ENCABEZADO -->
<div class="d-flex justify-content-between align-items-center mb-5 flex-wrap">


    <a href="/" class="btn btn-outline-success btn-lg shadow-sm">
        ⬅ Volver al inicio
    </a>

    <div class="text-center flex-grow-1">
        <h1 class="fw-bold text-success" style="font-size: 3rem;">
            🥑 Inventario Fruver
        </h1>

        <p class="text-gray-600">
            Gestiona tus frutas, verduras y hortalizas 🍎🥦🥕
        </p>
    </div>

</div>

    <!-- FORMULARIO -->
    <div class="card shadow-lg p-4 mb-5 border-0 rounded-4">
        <h4 class="mb-3 fw-bold text-success">➕ Agregar producto</h4>

        <form action="/productos/add" method="POST">
            <div class="row">
                <div class="col-md-4 mb-2">
                    <input type="text" name="nombre" placeholder="🍎 Nombre del producto" required class="form-control">
                </div>

                <div class="col-md-4 mb-2">
                    <input type="number" name="precio" placeholder="💰 Precio" required class="form-control">
                </div>

                <div class="col-md-4 mb-2">
                    <input type="number" name="stock" placeholder="📦 Stock" required class="form-control">
                </div>
            </div>

            <button class="btn btn-success w-100 mt-3">
                Guardar producto
            </button>
        </form>
    </div>

    <!-- TABLA -->
    <div class="card shadow-lg p-4 border-0 rounded-4">
        <h4 class="mb-3 fw-bold text-success">📋 Lista de productos</h4>

        <table class="table table-hover align-middle text-center">
            <thead class="table-success">
                <tr>
                    <th>🍎 Nombre</th>
                    <th>💰 Precio</th>
                    <th>📦 Stock</th>
                    <th>📌 Estado</th>
                    <th>⚙️ Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% productos.forEach(producto => { %>
                    <tr class="<%= producto.estado ? '' : 'table-danger' %>"></tr>
                        <td class="fw-semibold <%= producto.estado ? '' : 'text-decoration-line-through text-danger' %>">
    <%= producto.nombre %></td>
                        <td>$ <%= producto.precio %></td>
                        <td>
                            <span class="badge bg-success">
                                <%= producto.stock %>
                            </span>
                        </td>
                       <td>
    <% if (producto.estado) { %>

        <span class="badge bg-success">
            Activo
        </span>

    <% } else { %>

        <span class="badge bg-danger">
            Inactivo
        </span>

    <% } %>
</td>

<td>

    <a href="/editar/<%= producto.id %>" class="btn btn-warning btn-sm">
        ✏️ Editar
    </a>

    <% if (producto.estado) { %>

        <a href="/eliminar/<%= producto.id %>" class="btn btn-secondary btn-sm">
            🚫 Desactivar
        </a>

    <% } else { %>

        <a href="/activar/<%= producto.id %>" class="btn btn-success btn-sm">
            ✅ Activar
        </a>

    <% } %>

</td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    </div>

</div>

</body>
</html>